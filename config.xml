<?xml version='1.0' encoding='utf-8'?>
<widget id="com.nrnnaveen.sqlpractice" version="1.0.0"
    xmlns="http://www.w3.org/ns/widgets"
    xmlns:cdv="http://cordova.apache.org/ns/1.0">

    <name>SQL Practice</name>
    <description>SQL Practice Mobile – Learn SQL on the go.</description>
    <author email="nrnnaveen@example.com" href="https://github.com/nrnnaveen">
        M.NAVEEN
    </author>

    <!-- Entry Point -->
    <content src="index.html" />

    <!-- Access Permissions -->
    <access origin="*" />
    <allow-intent href="http://*/*" />
    <allow-intent href="https://*/*" />
    <allow-intent href="tel:*" />
    <allow-intent href="sms:*" />
    <allow-intent href="mailto:*" />
    <allow-intent href="geo:*" />
    <allow-intent href="market:*" />

    <!-- Global Preferences -->
    <preference name="loglevel" value="DEBUG" />
    <preference name="ShowTitle" value="true" />
    <preference name="AllowInlineMediaPlayback" value="true" />
    <preference name="EnableViewportScale" value="true" />
    <preference name="android-minSdkVersion" value="21" />
    <preference name="target-device" value="universal" />

    <!-- Android Platform -->
    <platform name="android">
        <preference name="Orientation" value="portrait" />
    </platform>

    <!-- iOS Platform -->
    <platform name="ios">
        <preference name="Orientation" value="portrait" />
    </platform>

    <!--
        InAppBrowser – required to open the system browser for Google OAuth.
        Without this plugin, window.open(..., "_system") falls back to the
        Cordova WebView, which Google blocks with error 403: disallowed_useragent.
    -->
    <plugin name="cordova-plugin-inappbrowser" spec="^5.0.0" />

    <!-- StatusBar Plugin -->
    <plugin name="cordova-plugin-statusbar" spec="^2.4.3">
        <variable name="StatusBarBackgroundColor" value="#667eea" />
        <variable name="StatusBarStyle" value="lightcontent" />
    </plugin>

    <!-- Splashscreen Plugin -->
    <plugin name="cordova-plugin-splashscreen" spec="^5.0.4" />

    <!-- Device Plugin (for debugging) -->
    <plugin name="cordova-plugin-device" spec="^2.1.0" />

    <!-- Whitelist Plugin -->
    <plugin name="cordova-plugin-whitelist" spec="^1.3.5" />

</widget>
