# ── Flask ────────────────────────────────────────────────────────────────────
SECRET_KEY=change_me_to_a_random_secret_key_at_least_32_chars

# ── Fernet encryption key (for per-user DB password storage) ─────────────────
# Generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
CIPHER_KEY=

# ── Google OAuth (optional) ──────────────────────────────────────────────────
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
# Explicit redirect URI registered in the Google Cloud Console.
# Example: https://your-app.onrender.com/login/google/callback
GOOGLE_OAUTH_REDIRECT_URI=

# ── Application URL ───────────────────────────────────────────────────────────
# Used to populate AUTHORIZED_JAVASCRIPT_ORIGINS and TRUSTED_ORIGINS.
# Example: https://your-app.onrender.com
APP_URL=

# ── MySQL (shared practice database) ─────────────────────────────────────────
MYSQL_HOST=localhost
MYSQL_PORT=3306
MYSQL_USER=root
MYSQL_PASSWORD=
MYSQL_DATABASE=test_db

# ── MySQL Admin (for creating per-user sandbox databases) ─────────────────────
# Defaults to the MYSQL_* values above when not set.
# Must have CREATE USER / CREATE DATABASE / GRANT privileges.
MYSQL_ADMIN_HOST=
MYSQL_ADMIN_PORT=
MYSQL_ADMIN_USER=
MYSQL_ADMIN_PASSWORD=

# ── PostgreSQL (shared practice database) ────────────────────────────────────
# Use either DATABASE_URL (Railway format) or individual variables:
# DATABASE_URL=postgresql://user:password@host:5432/dbname
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=postgres
POSTGRES_PASSWORD=
POSTGRES_DATABASE=test_db

# ── PostgreSQL Admin (for creating per-user sandbox databases) ────────────────
# Defaults to the POSTGRES_* values above when not set.
# Must be a superuser (can CREATE ROLE / CREATE DATABASE).
# Use POSTGRES_ADMIN_URL for a full connection string, or set individual vars.
POSTGRES_ADMIN_URL=
POSTGRES_ADMIN_HOST=
POSTGRES_ADMIN_PORT=
POSTGRES_ADMIN_USER=
POSTGRES_ADMIN_PASSWORD=
POSTGRES_ADMIN_DATABASE=postgres

# ── Database directory (SQLite users.db) ─────────────────────────────────────
# DB_DIR=/data/database

# ── Flask environment ─────────────────────────────────────────────────────────
FLASK_ENV=production
FLASK_DEBUG=0
